{
  "name": "hospital-management-system-root",
  "version": "1.0.0",
  "description": "Hospital Management System Root Package",
  "scripts": {
    "install-all": "npm install --prefix backend && npm install --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "build": "npm run build --prefix frontend",
    "backend": "npm run start --prefix backend",
    "backend-dev": "npm run dev --prefix backend",
    "frontend-dev": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
